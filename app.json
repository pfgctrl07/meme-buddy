{
  "expo": {
    "name": "Meme Buddy",
    "slug": "meme-buddy",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "memebuddy",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#050816"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.memebuddy.app",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.memebuddy.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#050816"
      }
    },
    "web": {
      "bundler": "metro"
    }
  }
}
